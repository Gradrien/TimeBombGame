generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  pinCode   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gamesPlayed      Int @default(0)
  gamesAsSherlock  Int @default(0)
  gamesAsMoriarty  Int @default(0)
  gamesWon         Int @default(0)
  winsSherlock     Int @default(0)
  winsMoriarty     Int @default(0)
  cablesCut        Int @default(0)
  bombsExploded    Int @default(0)
  loupesUsed       Int @default(0)
  cardsJammed      Int @default(0)
  consecutiveBombs Int @default(0)

  // --- NOUVELLE RELATION ---
  achievements UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(uuid())
  achievementId String // L'ID du succès (ex: "DEMOLITION_1")
  unlockedAt    DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  // On s'assure qu'un joueur ne débloque pas 2 fois le même succès
  @@unique([userId, achievementId])
}
